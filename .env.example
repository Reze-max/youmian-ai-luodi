# Vercel / 本地均可使用的环境变量
# 在 Vercel Dashboard -> Settings -> Environment Variables 设置
# 本地开发时复制为 .env.local（Vite 自动加载），注意 .env.local 已在 .gitignore

# === 必填：LLM API Key ===
LLM_API_KEY=

# === 可选：覆盖默认值 ===
LLM_PROVIDER=minimax
LLM_ENDPOINT=https://api.MiniMax.chat/v1/chat/completions
LLM_MODEL=MiniMax-M3

# === Vite 公开变量（前端可见，必须以 VITE_ 前缀）===
# 是否启用调试模式（控制台打印 token/耗时）
VITE_DEBUG=true
# 默认 LLM 模式：auto | real | mock
VITE_LLM_MODE=auto
